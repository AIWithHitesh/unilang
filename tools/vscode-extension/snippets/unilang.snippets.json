  "CLI Main": {
    "prefix": "cli-main",
    "body": [
      "import sys",
      "",
      "def parse_args(argv):",
      "    \"\"\"Parse command-line arguments.\"\"\"",
      "    val args = {}",
      "    val positional = []",
      "    var i = 1",
      "    while i < len(argv):",
      "        val arg = argv[i]",
      "        if arg.startswith(\"--\"):",
      "            val key = arg[2:]",
      "            if i + 1 < len(argv) and not argv[i + 1].startswith(\"--\"):",
      "                args[key] = argv[i + 1]",
      "                i += 2",
      "            else:",
      "                args[key] = True",
      "                i += 1",
      "        else:",
      "            positional.append(arg)",
      "            i += 1",
      "    return args, positional",
      "",
      "",
      "def main(argv):",
      "    val opts, positional = parse_args(argv)",
      "    ${1:# CLI logic here}",
      "    ${2:print(opts)}",
      "",
      "",
      "main(sys.argv)",
      "$0"
    ],
    "description": "CLI entry point skeleton with arg parsing"
