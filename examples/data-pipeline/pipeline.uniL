// pipeline.uniL — Data Processing / ETL Pipeline
// Demonstrates: CSV parsing, transformation, SQLite load, aggregate queries
// Run from repo root with:
//   unilang run examples/data-pipeline/pipeline.uniL

// ═══════════════════════════════════════════════════════════════════
//  EXTRACT — inline CSV data (sales records)
//  Columns: date, product, category, region, quantity, unit_price
// ═══════════════════════════════════════════════════════════════════

RAW_CSV = "date,product,category,region,quantity,unit_price
2024-01-05,Laptop Pro 15,Electronics,North,3,1299.99
2024-01-07,Wireless Mouse,Electronics,South,12,29.99
